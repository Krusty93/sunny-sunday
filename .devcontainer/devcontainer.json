{
	"name": "Sunny Sunday",
	"image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    },
		"ghcr.io/devcontainers/features/copilot-cli:1": {},
		"ghcr.io/devcontainers/features/python:1": {
			"version": "3.11"
		},
    "ghcr.io/devcontainers-extra/features/uv:1": {}
	},
  "postCreateCommand": "uv tool install specify-cli --from git+https://github.com/github/spec-kit.git && dotnet tool install -g Rnwood.Smtp4dev",
  "postStartCommand": {
    "set-workspace-as-safe-dir": "git config --global --add safe.directory ${containerWorkspaceFolder}",
    "dotnet-https-cert": "dotnet dev-certs https",
    "smtp4dev": "smtp4dev --urls http://0.0.0.0:3000 --smtpport 2525 --imapport 1143 --db /tmp/smtp4dev.db"
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "smtp4dev UI",
      "onAutoForward": "notify"
    }
  },
	"customizations": {
		"vscode": {
      "extensions": [
        "-ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-vscode.vscode-websearchforcopilot",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "github.copilot",
        "github.copilot-chat",
        "yzhang.markdown-all-in-one",
        "DavidAnson.vscode-markdownlint",
        "ionutvmi.path-autocomplete",
        "humao.rest-client",
        "alexcvzz.vscode-sqlite"
      ]
    }
	}
}
