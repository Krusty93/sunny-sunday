FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY src/ ./
RUN dotnet restore SunnySunday.Cli/SunnySunday.Cli.csproj
RUN dotnet publish SunnySunday.Cli/SunnySunday.Cli.csproj \
    --configuration Release \
    --output /out \
    --no-restore

FROM mcr.microsoft.com/dotnet/runtime:10.0 AS runtime
WORKDIR /app

COPY --from=build /out/ ./

ENV SUNNY_SERVER=http://localhost:8080

ENTRYPOINT ["dotnet", "SunnySunday.Cli.dll"]