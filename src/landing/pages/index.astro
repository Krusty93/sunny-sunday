---
import { Image } from 'astro:assets';
import { siteConfig } from '../config/site';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import heroImage from '../assets/hero-kindle.jpg';
---

<Layout title={siteConfig.name}>
	<Navbar />
	<main>
		<!-- Hero -->
		<section id="hero" class="relative min-h-[80vh] overflow-hidden">
			<!-- Full-bleed background image -->
			<Image
				src={heroImage}
				alt="A Kindle displaying a highlights recap generated by Relego"
				class="absolute inset-0 h-full w-full object-cover"
				widths={[800, 1200, 1920]}
				sizes="100vw"
			/>
			<!-- Gradient overlay: solid bg on left → transparent on right -->
			<div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-[var(--color-bg)] via-[var(--color-bg)] via-25% to-transparent to-65%"></div>
			<!-- Text content on the left -->
			<div class="relative z-10 mx-auto flex min-h-[80vh] max-w-6xl items-center px-6">
				<div class="flex max-w-lg flex-col gap-6">
					<h1 class="text-5xl font-light tracking-tight text-[var(--color-text)] sm:text-7xl">
						{siteConfig.logotype}
					</h1>
					<p class="text-lg leading-relaxed text-[var(--color-text)]/80">
						{siteConfig.tagline}
					</p>
					<div>
						<Button href="#getting-started" variant="primary">Get started</Button>
					</div>
				</div>
			</div>
		</section>

		<!-- Placeholder for getting-started (scroll target) -->
		<section id="getting-started" class="mx-auto w-full max-w-6xl px-6 py-20">
			<h2 class="text-3xl tracking-tight text-[var(--color-text)] sm:text-4xl">Getting Started</h2>
		</section>
	</main>
	<Footer />
</Layout>
