---
import { siteConfig } from '../config/site';
import Layout from '../layouts/Layout.astro';
---

<Layout title={siteConfig.name}>
	<main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-6 py-24">
		<h1 class="text-5xl font-light tracking-tight text-[var(--color-text)] sm:text-7xl">
			{siteConfig.logotype}
		</h1>
	</main>
</Layout>