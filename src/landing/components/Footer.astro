---
import { siteConfig } from '../config/site';
---

<footer class="border-t border-[var(--color-border)] py-8 text-center text-sm text-[var(--color-text)]/60">
	<p>{siteConfig.name} · <a href={siteConfig.licenseUrl} target="_blank" rel="noopener noreferrer" class="underline decoration-[var(--color-text)]/30 underline-offset-2 transition-colors hover:text-[var(--color-text)]">{siteConfig.license} License</a></p>
</footer>
