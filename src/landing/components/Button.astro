---
interface Props {
	href: string;
	variant?: 'primary' | 'outline';
	class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base = 'inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:ring-offset-2';

const variants = {
	primary: 'bg-[var(--color-accent)] text-white hover:opacity-90',
	outline: 'border border-[var(--color-border)] text-[var(--color-text)] hover:bg-[var(--color-surface)]',
};
---

<a href={href} class:list={[base, variants[variant], className]}>
	<slot />
</a>
