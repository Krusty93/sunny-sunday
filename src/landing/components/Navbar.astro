---
import { siteConfig } from '../config/site';
import ThemeToggle from './ThemeToggle.astro';
---

<nav class="fixed top-0 z-50 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-md">
	<div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
		<a href="#" aria-label="relego. — go to top" class="font-['Playfair_Display'] text-xl font-light text-[var(--color-text)]">
			{siteConfig.logotype}
		</a>
		<div class="flex items-center gap-3">
			<ThemeToggle />
			<a
				href={siteConfig.githubUrl}
				target="_blank"
				rel="noopener noreferrer"
				class:list={['hidden sm:inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:ring-offset-2 border border-[var(--color-border)] text-[var(--color-text)] hover:bg-[var(--color-surface)]']}
			>
				<span>View on GitHub</span>
				<svg aria-hidden="true" class="ml-1.5 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
					<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3" />
				</svg>
			</a>
			<!-- Mobile GitHub link -->
			<a
				href={siteConfig.githubUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-[var(--color-text)] transition-colors hover:bg-[var(--color-surface)] sm:hidden"
				aria-label="View on GitHub"
			>
				<svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
					<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
				</svg>
			</a>
		</div>
	</div>
</nav>
