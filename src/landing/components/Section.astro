---
interface Props {
	id: string;
	title?: string;
	class?: string;
}

const { id, title, class: className = '' } = Astro.props;
---

<section id={id} class:list={['mx-auto w-full max-w-6xl px-6 py-20', className]}>
	{title && <h2 class="mb-12 text-3xl tracking-tight text-[var(--color-text)] sm:text-4xl">{title}</h2>}
	<slot />
</section>
